{
  "name": "fokus",
  "version": "1.0.0-lite-beta",
  "description": "SuperFokus Lite is a lightweight Electron edition focused on core productivity modes without system-level blocking.",
  "main": "src/main/main.js",
"scripts": {
  "start": "electron .",
  "test": "echo \"Error: no test specified\" && exit 1",
  "dist": "electron-builder --win",
  "dist:mac": "electron-builder --mac",
  "dist:win": "electron-builder --win",
  "dist:all": "electron-builder --mw"
},
"build": {
    "appId": "com.superfokus-lite.app",
    "productName": "SuperFokus-Lite",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/fokusicon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "asar": true,
    "asarUnpack": [],
    "files": [
      "src/**/*",
      "assets/**/*",
      "index.html",
      "package.json"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "electron-store": "^11.0.2"
  }
}
